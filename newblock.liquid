{% assign updates = site.data.updates %}
{% assign sorted_keys = updates | sort | reverse %}
{% for key in sorted_keys %}
{% assign update = updates[key] %}
            <div class="changelog-section">
                <h2 class="changelog-date">{{ update.date }} - {{ update.title }}</h2>

                <div class="changelog-overview">
                    <p><strong>概述：</strong>{{ update.overview }}</p>
                </div>

                {% for category in update.categories %}
                <div class="changelog-category">
                    <h3 class="category-title">{{ category.title }}</h3>
                    <ul class="changes-list">
                        {% for change in category.changes %}
                        <li>
                            {% if change.type %}
                            <span class="{{ change.type }}">{{ change.type | capitalize }}</span> {{ change.text | markdownify }}
                            {% else %}
                            {{ change.text | markdownify }}
                            {% endif %}
                        </li>
                        {% endfor %}
                    </ul>
                </div>
                {% endfor %}

                <div style="text-align: center;">
                    <a href="../index.html" class="back-to-home">返回首页</a>
                </div>
            </div>
{% endfor %}